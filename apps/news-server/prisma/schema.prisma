datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model News {
  author          String?
  content         String?
  createdAt       DateTime  @default(now())
  id              String    @id @default(cuid())
  imageUrl        String?
  isPublished     Boolean?
  publicationDate DateTime?
  summary         String?
  title           String?
  updatedAt       DateTime  @updatedAt
  user            User?     @relation(fields: [userId], references: [id])
  userId          String?
}

model NewsMedia {
  createdAt   DateTime @default(now())
  description String?
  id          String   @id @default(cuid())
  typeField   String?
  updatedAt   DateTime @updatedAt
  url         String?
}

model User {
  createdAt DateTime @default(now())
  email     String?  @unique
  firstName String?
  id        String   @id @default(cuid())
  lastName  String?
  newsItems News[]
  password  String
  roles     Json
  updatedAt DateTime @updatedAt
  username  String   @unique
}
